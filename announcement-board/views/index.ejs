<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title>Дошка оголошень</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="container">

  <h1>Дошка оголошень</h1>

  <form class="filters" method="GET">

    <input
      type="text"
      name="search"
      placeholder="Шукати оголошення..."
      value="<%= search %>"
    >

    <select name="sort">

      <option
        value="newest"
        <%= sort === 'newest' ? 'selected' : '' %>
      >
        Новіші спочатку
      </option>

      <option
        value="oldest"
        <%= sort === 'oldest' ? 'selected' : '' %>
      >
        Старіші спочатку
      </option>

    </select>

    <button type="submit">
      Знайти
    </button>

    <a class="btn" href="/announcements">
      Додати оголошення
    </a>

  </form>

  <% if (announcements.length === 0) { %>

    <p>Оголошень не знайдено</p>

  <% } %>

  <% announcements.forEach(ann => { %>

    <div class="card">

      <h2><%= ann.title %></h2>

      <p>
        <%= ann.description.substring(0, 100) %>...
      </p>

      <div class="meta">

        <span>
          <%= categoryMap[ann.category] %>
        </span>

        <span>
          <%= ann.price %> грн
        </span>

      </div>

      <small>
        <%= new Date(ann.createdAt).toLocaleDateString('uk-UA') %>
      </small>

      <br><br>

      <a href="/announcements/<%= ann.id %>">
        Детальніше
      </a>

    </div>

  <% }) %>

  <% if (totalPages > 1) { %>

    <div class="pagination">

      <% if (currentPage > 1) { %>

        <a
          href="/?page=<%= currentPage - 1 %>&search=<%= search %>&sort=<%= sort %>"
        >
          Попередня
        </a>

      <% } %>

      <% for(let i = 1; i <= totalPages; i++) { %>

        <a
          class="<%= currentPage === i ? 'active' : '' %>"
          href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>"
        >
          <%= i %>
        </a>

      <% } %>

      <% if (currentPage < totalPages) { %>

        <a
          href="/?page=<%= currentPage + 1 %>&search=<%= search %>&sort=<%= sort %>"
        >
          Наступна
        </a>

      <% } %>

    </div>

  <% } %>

</div>

</body>
</html>