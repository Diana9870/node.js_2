<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title>Нове оголошення</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="container">

  <h1>Створити оголошення</h1>

  <form method="POST" action="/announcements">

    <div class="field">

      <label>Категорія</label>

      <label>
        <input
          type="radio"
          name="category"
          value="sale"
          <%= data?.category === 'sale' ? 'checked' : '' %>
        >
        📦 Продаж
      </label>

      <label>
        <input
          type="radio"
          name="category"
          value="service"
          <%= data?.category === 'service' ? 'checked' : '' %>
        >
        🔧 Послуги
      </label>

      <label>
        <input
          type="radio"
          name="category"
          value="job"
          <%= data?.category === 'job' ? 'checked' : '' %>
        >
        💼 Робота
      </label>

      <label>
        <input
          type="radio"
          name="category"
          value="other"
          <%= data?.category === 'other' ? 'checked' : '' %>
        >
        📌 Інше
      </label>

      <% if (errors.category) { %>
        <p class="error"><%= errors.category %></p>
      <% } %>

    </div>

    <div class="field">

      <label>Назва</label>

      <input
        type="text"
        name="title"
        required
        minlength="5"
        maxlength="100"
        placeholder="Коротка назва оголошення"
        value="<%= data?.title || '' %>"
      >

      <% if (errors.title) { %>
        <p class="error"><%= errors.title %></p>
      <% } %>

    </div>

    <div class="field">

      <label>Опис</label>

      <textarea
        name="description"
        rows="6"
        required
        minlength="10"
        placeholder="Детальний опис оголошення..."
      ><%= data?.description || '' %></textarea>

      <% if (errors.description) { %>
        <p class="error"><%= errors.description %></p>
      <% } %>

    </div>

    <div class="field">

      <label>Ціна</label>

      <input
        type="number"
        name="price"
        min="0"
        step="0.01"
        required
        value="<%= data?.price || '' %>"
      >

      <% if (errors.price) { %>
        <p class="error"><%= errors.price %></p>
      <% } %>

    </div>

    <div class="field">

      <label>Контакти</label>

      <input
        type="text"
        name="contactInfo"
        required
        minlength="5"
        placeholder="Email або телефон"
        value="<%= data?.contactInfo || '' %>"
      >

      <% if (errors.contactInfo) { %>
        <p class="error"><%= errors.contactInfo %></p>
      <% } %>

    </div>

    <button type="submit">
      Опублікувати
    </button>

    <a class="btn" href="/">
      Скасувати
    </a>

  </form>

</div>

</body>
</html>